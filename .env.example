# Copy to .env and fill in
# These are BUILD-TIME constants embedded into the extension bundle.

# Sentry DSN - get from sentry.io after creating an "applyforge" project
# Leave blank to disable Sentry entirely
WXT_SENTRY_DSN=

# Release tag (auto-injected by CI; set manually for local dev if you care)
WXT_RELEASE=applyforge@0.1.0
