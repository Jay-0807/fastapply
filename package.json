{
  "name": "applyforge",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered Chrome extension that auto-fills activity application forms using your project documents and learns from each submission.",
  "type": "module",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "predev": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-icons.mjs",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@sentry/browser": "^8.40.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.8.0",
    "marked": "^15.0.3",
    "openai": "^4.73.0",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.1",
    "tailwind-merge": "^2.5.4",
    "uuid": "^11.0.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@types/chrome": "^0.0.280",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@wxt-dev/module-react": "^1.1.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^15.11.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.1.5",
    "wxt": "^0.19.13"
  }
}
